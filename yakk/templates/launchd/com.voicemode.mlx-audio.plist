<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- com.yakk.mlx-audio.plist v2.1.0 -->
<!-- Last updated: 2026-04-27 -->
<!-- mlx-audio: unified Whisper STT + Kokoro TTS + Qwen3-TTS clone-voice on Apple Silicon -->
<!-- Calls mlx_audio.server directly from `uv tool install mlx-audio` location. -->
<!-- Sources yakk.env for YAKK_MLX_AUDIO_HOST / YAKK_MLX_AUDIO_PORT. -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.yakk.mlx-audio</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>-c</string>
        <string>set -a; [ -f "$HOME/.yakk/yakk.env" ] &amp;&amp; . "$HOME/.yakk/yakk.env"; set +a; LOG_DIR="$HOME/.yakk/logs/mlx-audio"; mkdir -p "$LOG_DIR"; cd "$LOG_DIR"; exec "$HOME/.local/bin/mlx_audio.server" --host "${{YAKK_MLX_AUDIO_HOST:-127.0.0.1}}" --port "${{YAKK_MLX_AUDIO_PORT:-8890}}" --log-dir "$LOG_DIR"</string>
    </array>
    <key>WorkingDirectory</key>
    <string>{HOME}/.yakk/logs/mlx-audio</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>{HOME}/.yakk/logs/mlx-audio/mlx-audio.out.log</string>
    <key>StandardErrorPath</key>
    <string>{HOME}/.yakk/logs/mlx-audio/mlx-audio.err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>{HOME}/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
    </dict>
</dict>
</plist>
